# Filebase S3 Storage Configuration
FILEBASE_ACCESS_KEY=your_access_key_here
FILEBASE_SECRET_KEY=your_secret_key_here
FILEBASE_BUCKET=your_bucket_name
FILEBASE_ENDPOINT=https://s3.filebase.com

# Database (SQLite for local, Filebase syncs on commit)
DATABASE_URL=sqlite:///doctorlink.db

# JWT Secrets (change these!)
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256

# Stripe (get from stripe dashboard)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

